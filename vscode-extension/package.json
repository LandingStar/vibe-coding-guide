{
  "name": "doc-based-coding",
  "displayName": "Doc-Based Coding",
  "description": "Document-driven governance workflow platform for VS Code — enforces project constraints, manages pack topology, and provides AI-assisted governance across all IDE operations.",
  "version": "0.1.3",
  "publisher": "doc-based-coding",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/doc-based-coding/vscode-extension"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "keywords": [
    "governance",
    "document-driven",
    "constraints",
    "MCP",
    "copilot"
  ],
  "activationEvents": [
    "workspaceContains:.codex/platform.json",
    "onChatParticipant:docBasedCoding.governance"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "docBasedCoding.governance",
        "fullName": "Doc-Based Coding Governance",
        "name": "governance",
        "description": "Ask about project constraints, check governance decisions, view packs, and get guidance on document-driven workflows.",
        "isSticky": false,
        "commands": [
          {
            "name": "check",
            "description": "Check current constraint status (C1-C8)"
          },
          {
            "name": "decide",
            "description": "Run governance decision on an action"
          },
          {
            "name": "constraints",
            "description": "View all constraint details"
          },
          {
            "name": "packs",
            "description": "List loaded packs"
          },
          {
            "name": "dogfood",
            "description": "Run dogfood evidence pipeline: evaluate symptoms, promote issues, generate feedback"
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "doc-based-coding",
          "title": "Doc-Based Coding",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "doc-based-coding": [
        {
          "id": "constraintDashboard",
          "name": "Constraints (C1-C8)"
        },
        {
          "id": "packExplorer",
          "name": "Pack Explorer"
        },
        {
          "id": "decisionLogViewer",
          "name": "Decision Log"
        },
        {
          "id": "configExplorer",
          "name": "Config Explorer"
        },
        {
          "id": "configPanel",
          "name": "Config Editor",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "docBasedCoding.refreshConstraints",
        "title": "Refresh Constraints",
        "icon": "$(refresh)",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.startServer",
        "title": "Start MCP Server",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.stopServer",
        "title": "Stop MCP Server",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.openProgressGraphPreview",
        "title": "Open Progress Graph Preview",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.refreshProgressGraphPreview",
        "title": "Refresh Progress Graph Preview",
        "icon": "$(refresh)",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.revealProgressGraphPreviewArtifact",
        "title": "Reveal Progress Graph Preview Artifact",
        "icon": "$(go-to-file)",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.setupWizard",
        "title": "Setup Wizard",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.refreshPacks",
        "title": "Refresh Packs",
        "icon": "$(refresh)",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.refreshDecisionLogs",
        "title": "Refresh Decision Logs",
        "icon": "$(refresh)",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.filterDecisionLogsMergeConflicts",
        "title": "Filter by Merge Conflicts",
        "icon": "$(filter)",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.classifyIntent",
        "title": "Classify Intent (AI Model)",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.generatePackDescription",
        "title": "Generate Pack Description (AI Model)",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.generatePackRules",
        "title": "Generate Pack Rules (AI Model)",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.openReviewPanel",
        "title": "Open Governance Review Panel",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.diagnose",
        "title": "Diagnose Connection",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.refreshConfig",
        "title": "Refresh Config",
        "icon": "$(refresh)",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.editConfigItem",
        "title": "Edit Config Value",
        "icon": "$(edit)",
        "category": "Doc-Based Coding"
      },
      {
        "command": "docBasedCoding.selectModel",
        "title": "Select LLM Model",
        "category": "Doc-Based Coding"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "docBasedCoding.refreshConstraints",
          "when": "view == constraintDashboard",
          "group": "navigation"
        },
        {
          "command": "docBasedCoding.refreshPacks",
          "when": "view == packExplorer",
          "group": "navigation"
        },
        {
          "command": "docBasedCoding.refreshDecisionLogs",
          "when": "view == decisionLogViewer",
          "group": "navigation"
        },
        {
          "command": "docBasedCoding.filterDecisionLogsMergeConflicts",
          "when": "view == decisionLogViewer",
          "group": "navigation"
        },
        {
          "command": "docBasedCoding.refreshConfig",
          "when": "view == configExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "docBasedCoding.editConfigItem",
          "when": "view == configExplorer && viewItem == configEditable",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Doc-Based Coding",
      "properties": {
        "docBasedCoding.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Python executable used for the MCP server. If empty, uses the workspace Python environment."
        },
        "docBasedCoding.serverMode": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "module", "command"],
          "enumDescriptions": [
            "Auto-detect: try 'doc-based-coding-mcp' entry point first, fall back to 'python -m src.mcp.server'",
            "Use 'python -m src.mcp.server' (requires editable install or src/ in project)",
            "Use 'doc-based-coding-mcp' CLI entry point (requires pip install of .whl)"
          ],
          "description": "How to launch the MCP governance server."
        },
        "docBasedCoding.serverArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional arguments passed to the MCP server."
        },
        "docBasedCoding.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the MCP server when the extension activates."
        },
        "docBasedCoding.terminal.killOnBlock": {
          "type": "boolean",
          "default": false,
          "description": "Automatically kill terminal commands that are blocked by governance. When false, shows a warning with an option to kill manually."
        },
        "docBasedCoding.llm.family": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Language model family used for extension AI features (intent classification, pack generation, governance explanations). Current default provider: GitHub Copilot. Examples: gpt-4o, gpt-4o-mini, claude-3.5-sonnet, o1-preview."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs --production",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src/",
    "test": "npm run build && node ./dist/test/runTest.js",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.93.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^3.9.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  }
}
